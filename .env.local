# Generic / backend
SPACETIMEDB_DB_NAME=nyc-pulse
SPACETIMEDB_HOST=ws://localhost:3000

# Vite  (client reads only these two)
VITE_SPACETIMEDB_DB_NAME=nyc-pulse
# Maincloud (deployed). To run against the local server instead, swap back to:
#   VITE_SPACETIMEDB_HOST=ws://localhost:3000
VITE_SPACETIMEDB_HOST=wss://maincloud.spacetimedb.com

# Next.js
NEXT_PUBLIC_SPACETIMEDB_DB_NAME=nyc-pulse
NEXT_PUBLIC_SPACETIMEDB_HOST=ws://localhost:3000

# Create React App
REACT_APP_SPACETIMEDB_DB_NAME=nyc-pulse
REACT_APP_SPACETIMEDB_HOST=ws://localhost:3000

# Expo
EXPO_PUBLIC_SPACETIMEDB_DB_NAME=nyc-pulse
EXPO_PUBLIC_SPACETIMEDB_HOST=ws://localhost:3000

# SvelteKit
PUBLIC_SPACETIMEDB_DB_NAME=nyc-pulse
PUBLIC_SPACETIMEDB_HOST=ws://localhost:3000
